# PostgreSQL Database Configuration
DATABASE_URL=postgresql://querycraft_user:querycraft_pass@localhost:5432/querycraft_main

# Provider selection (Gemini remains safe default if invalid/missing)
LLM_PROVIDER=gemini
LLM_PROVIDER_ORDER=openai,anthropic,gemini

# Provider API keys (only required for providers you enable/order)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model (gemini-2.5-flash, gemini-2.0-flash, gemini-pro, etc.)
GEMINI_MODEL=gemini-2.5-flash

# LLM Configuration
LLM_TIMEOUT=10
LLM_MAX_RETRIES=3

# gRPC Configuration
GRPC_VERBOSITY=ERROR


# Firebase authentication
FIREBASE_CREDENTIALS_PATH= "privateKey.json download from firebase"
