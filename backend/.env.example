# PostgreSQL Database Configuration
DATABASE_URL=postgresql://querycraft_user:querycraft_pass@localhost:5432/querycraft_main

# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=model_name

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=model_name

# OpenAi API Configuration
# OPENAI_API_KEY=your_openai_api_key_here

# Ollama API Configuration
# OLLAMA_API_KEY=your_ollama_api_key_here
# OLLAMA_MODEL=model

# Provider selection - Gemini is default, OpenRouter is fallback
LLM_PROVIDER=gemini
LLM_PROVIDER_ORDER=gemini,openrouter

# LLM Configuration
LLM_TIMEOUT=10
LLM_MAX_RETRIES=3

# gRPC Configuration
GRPC_VERBOSITY=ERROR

# Firebase authentication
FIREBASE_CREDENTIALS_PATH=./privateKey.json
